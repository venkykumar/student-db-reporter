CI_ENVIRONMENT=development

app.baseURL=http://localhost:8080/
app.indexPage=

database.default.hostname=db
database.default.database=student_db
database.default.username=student_user
database.default.password=secret
database.default.port=3306
database.default.DBDriver=MySQLi
database.default.charset=utf8mb4

# Anthropic API key — set ONE of the following:
#   Option 1: set ANTHROPIC_API_KEY in your shell/environment (no entry here needed)
#   Option 2: set it explicitly here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# CLAUDE_API_KEY=sk-ant-your-key-here

CLAUDE_MODEL=claude-sonnet-4-6
